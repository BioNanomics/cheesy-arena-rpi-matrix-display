# Copy to /etc/cheesy-display/config.env and edit for the actual event/station.
CHEESY_FMS_IP=10.0.100.5
CHEESY_STATION=B1
CHEESY_SINK=matrix
CHEESY_MATRIX_ROWS=32
CHEESY_MATRIX_COLS=64
CHEESY_MATRIX_HARDWARE_MAPPING=adafruit-hat
CHEESY_MATRIX_GPIO_SLOWDOWN=2
CHEESY_MATRIX_BRIGHTNESS=100
CHEESY_MATRIX_PWM_BITS=11
# Startup default only -- once running, switch live from Cheesy Arena's own
# Setup -> Displays page by editing this display's Configuration box to
# "mode=basic" (border/ESTOP-BYPASS-alerts/idle accent-bars off) or clearing
# it back out (full-featured). No restart needed either way.
CHEESY_BASIC_MODE=false
