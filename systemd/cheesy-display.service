[Unit]
Description=Cheesy Arena RPi Matrix Display
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=/etc/cheesy-display/config.env
WorkingDirectory=/opt/cheesy-arena-rpi-matrix-display
ExecStart=/opt/cheesy-arena-rpi-matrix-display/venv/bin/python3 main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
