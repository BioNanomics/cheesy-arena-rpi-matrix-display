[Unit]
Description=Cheesy Arena RPi Matrix Display
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/etc/cheesy-display/config.env
WorkingDirectory=/home/admin/cheesy-arena-rpi-matrix-display
ExecStart=/home/admin/cheesy-venv/bin/python3 main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
